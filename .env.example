# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://feedsomeone.org

# Supabase — local: http://127.0.0.1:54321 | cloud: from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase cloud bootstrap only (supabase link --project-ref ...)
SUPABASE_ACCESS_TOKEN=

# Payment provider: mock (Day 1) | stripe (Day 2+)
PAYMENT_PROVIDER=mock|stripe

# Mock payment provider — HMAC-signed Stripe-shaped webhooks
MOCK_WEBHOOK_SECRET=
# 0 = manual confirm required, 1 = auto-confirm every mock payment
MOCK_AUTOCONFIRM=0|1

# Stripe (Day 2 — leave blank until keys arrive)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email provider: local (writes to email_outbox table) | resend
EMAIL_PROVIDER=local|resend
RESEND_API_KEY=
EMAIL_FROM=FeedSomeone <photos@feedsomeone.org>

# Cron auth — Firebase scheduled functions and dev-cron.mjs both use this
CRON_SECRET=

# Test mode: 1 = enables test helpers, overrides clock, etc.
TEST_MODE=0|1

# Currency fallback when IP geo fails
GEO_FALLBACK_CURRENCY=USD

# Minimum visible counts on homepage stats band (suppress until real data)
STATS_MIN_MEALS=500
STATS_MIN_DONORS=100
